# =============================================================================
# Cloud Timeline - Environment Variables Template
# =============================================================================
# Copy this file to .env.local and fill in your actual values
# NEVER commit .env.local to version control!
# =============================================================================

# -----------------------------------------------------------------------------
# Next.js Configuration
# -----------------------------------------------------------------------------
NODE_ENV=production
NEXT_PUBLIC_APP_URL=https://your-app.azurestaticapps.net

# -----------------------------------------------------------------------------
# Authentication (Required for Login)
# -----------------------------------------------------------------------------

# NextAuth Secret: (Must be >= 256 bits / 32 bytes)
# Windows: $bytes = New-Object Byte[] 32; (New-Object System.Security.Cryptography.RNGCryptoServiceProvider).GetBytes($bytes); [Convert]::ToBase64String($bytes)
# Mac/Linux: openssl rand -base64 32
NEXTAUTH_SECRET=your-256bit-secret-here

# -----------------------------------------------------------------------------
# Data Encryption (Required for Field-Level Security)
# -----------------------------------------------------------------------------
# MUST be 32 bytes (256 bits) base64 encoded.
# Use same generation command as NEXTAUTH_SECRET.
# DO NOT LOSE THIS KEY or data will be permanently unrecoverable.
MASTER_ENCRYPTION_KEY=your-32byte-base64-key-here

# -----------------------------------------------------------------------------
# Authentication Providers
# -----------------------------------------------------------------------------
# GitHub: Get from https://github.com/settings/developers
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# Google: Get from https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Azure Active Directory (Optional): Get from Azure Portal > App Registrations
NEXT_PUBLIC_AZURE_CLIENT_ID=your-azure-client-id
NEXT_PUBLIC_AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_SECRET=your-azure-client-secret

# -----------------------------------------------------------------------------
# Azure Storage (Blob Storage for Media Files)
# -----------------------------------------------------------------------------
# Get these from Azure Portal > Storage Accounts
AZURE_STORAGE_ACCOUNT=yourstorageaccount
AZURE_STORAGE_KEY=your-storage-key-here
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=yourstorageaccount;AccountKey=your-key;EndpointSuffix=core.windows.net

# -----------------------------------------------------------------------------
# Azure Cosmos DB (NoSQL Database)
# -----------------------------------------------------------------------------
# Get these from Azure Portal > Cosmos DB
AZURE_COSMOS_ENDPOINT=https://your-cosmosdb.documents.azure.com:443/
AZURE_COSMOS_KEY=your-cosmos-key-here
AZURE_COSMOS_DATABASE=timeline-db
AZURE_COSMOS_CONTAINER=timeline-entries

# -----------------------------------------------------------------------------
# Azure Cognitive Services - Computer Vision
# -----------------------------------------------------------------------------
# Get these from Azure Portal > Cognitive Services > Computer Vision
AZURE_COGNITIVE_VISION_KEY=your-vision-key-here
AZURE_COGNITIVE_VISION_ENDPOINT=https://your-region.api.cognitive.microsoft.com/

# -----------------------------------------------------------------------------
# Azure Cognitive Services - Speech (for Audio Transcription)
# -----------------------------------------------------------------------------
# Get these from Azure Portal > Cognitive Services > Speech
AZURE_COGNITIVE_SPEECH_KEY=your-speech-key-here
AZURE_COGNITIVE_SPEECH_REGION=eastus

# -----------------------------------------------------------------------------
# Azure Cognitive Services - Text Analytics (for Sentiment Analysis)
# -----------------------------------------------------------------------------
# Get these from Azure Portal > Cognitive Services > Language
AZURE_COGNITIVE_TEXT_KEY=your-text-analytics-key-here
AZURE_COGNITIVE_TEXT_ENDPOINT=https://your-region.api.cognitive.microsoft.com/

# -----------------------------------------------------------------------------
# Optional: Analytics & Monitoring
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_ANALYTICS_ID=your-analytics-id
# NEXT_PUBLIC_SENTRY_DSN=your-sentry-dsn
